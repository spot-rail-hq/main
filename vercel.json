{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.srhq.uk"
        }
      ],
      "destination": "https://srhq.uk/$1",
      "permanent": true
    },
    {
      "source": "/news.html",
      "destination": "/news",
      "permanent": true
    },
    {
      "source": "/departures.html",
      "destination": "/departures",
      "permanent": true
    },
    {
      "source": "/database.html",
      "destination": "/database",
      "permanent": true
    },
    {
      "source": "/map.html",
      "destination": "/map",
      "permanent": true
    }
  ]
}
